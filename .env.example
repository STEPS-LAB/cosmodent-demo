# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================

# Environment
NODE_ENV=development

# Server
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/cosmodent

# JWT Security - CRITICAL: Change these in production!
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS - Comma-separated list of allowed origins
# Production: https://yourdomain.com,https://admin.yourdomain.com
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# API URL for frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket URL
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Site configuration
NEXT_PUBLIC_SITE_NAME=CosmoDent
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# EMAIL CONFIGURATION (optional)
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================

MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# =============================================================================
# PRODUCTION CHECKLIST
# =============================================================================
# 1. Change JWT_SECRET to a strong random value (min 32 characters)
# 2. Set NODE_ENV=production
# 3. Update CORS_ORIGIN to your actual domain(s)
# 4. Use HTTPS in production (set secure cookies automatically)
# 5. Set strong MongoDB password in MONGODB_URI
# 6. Configure proper SMTP credentials
# 7. Enable helmet CSP in production (server.ts)
