# ============================================================
# COSMODENT — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend Server
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme_secure_password
MONGO_DB_NAME=cosmodent
MONGODB_URI=mongodb://admin:changeme_secure_password@localhost:27017/cosmodent?authSource=admin

# JWT Authentication
JWT_SECRET=changeme_jwt_secret_minimum_32_characters_here_please
JWT_EXPIRES_IN=7d

# Initial Admin Credentials (used by seed script)
ADMIN_EMAIL=admin@cosmodent.ua
ADMIN_PASSWORD=Admin@123456

# Frontend Environment Variables
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# AI Suggestions (optional — leave blank to disable)
OPENAI_API_KEY=sk-your-openai-key-here

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
